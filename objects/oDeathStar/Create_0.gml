/// @description Death Star background initialization
/// Sets up the Death Star sprite's initial position and scale.
/// The Death Star appears as a background element, slowly moving upward
/// and scaling as it approaches to create a dramatic visual effect.
///
/// @var yoffset - Vertical offset for scrolling effect (starts at 0, moves upward)
/// @var scale - Scaling factor for size effect (starts at 1, increases over time)

yoffset = 0;
scale = 1;
